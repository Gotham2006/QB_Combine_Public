    "# 7. Final model\n",
    "x_final = x_scaled_df[selected_features]\n",
    "x_final = sm.add_constant(x_final)\n",
    "\n",
    "logit_model = sm.Logit(y, x_final)\n",
    "result = logit_model.fit()\n",
    "\n",
    "# 8. Save output\n",
    "with open(\"ML_Model_Outputs/lasso_logit_model_summary_scaled.txt\", \"w\") as f:\n",
