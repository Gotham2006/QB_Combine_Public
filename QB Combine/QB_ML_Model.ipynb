    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.impute import SimpleImputer\n",
    "from sklearn.preprocessing import RobustScaler\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.model_selection import cross_val_score\n",
    "import os\n",
    "\n",
    "# 1. Load data\n",
    "df = pd.read_csv('Data_Cleaning/QB_Combine_Data.csv')\n",
    "\n",
    "# 2. Convert height/broad\n",
    "def convert_to_inches(val):\n",
    "    if pd.isna(val):\n",
    "        return np.nan\n",
    "    try:\n",
    "        v = str(val).strip()\n",
    "        if \"'\" in v:\n",
    "            parts = v.replace('\"', '').split(\"'\")\n",
    "            return int(parts[0]) * 12 + (int(parts[1]) if parts[1] else 0)\n",
    "        return float(v)\n",
    "    except:\n",
    "        return np.nan\n",
    "\n",
    "df['Height'] = df['Height'].apply(convert_to_inches)\n",
    "df['Broad_Jump'] = df['Broad'].apply(convert_to_inches)\n",
    "\n",
    "# 3. Target column\n",
    "pff_col = [c for c in df.columns if 'PFF' in c.upper()][0]\n",
    "df[pff_col] = pd.to_numeric(df[pff_col], errors='coerce')\n",
    "\n",
    "# Drop missing target\n",
    "df = df.dropna(subset=[pff_col])\n",
    "\n",
    "# 4. Convert to classification target\n",
    "median_pff = df[pff_col].median()\n",
    "y = (df[pff_col] >= median_pff).astype(int)\n",
    "\n",
    "# 5. Features\n",
    "features = [\n",
    "    'Height', 'Weight', 'Hands', 'Arms',\n",
    "    '40 Yd', 'Vertical', 'Broad_Jump', '3-Cone', 'Shuttle'\n",
    "]\n",
    "\n",
    "x = df[features]\n",
    "\n",
    "# 6. Imputation\n",
    "imputer = SimpleImputer(strategy='median')\n",
    "x_imputed = imputer.fit_transform(x)\n",
    "\n",
    "# 7. Robust scaling \n",
    "scaler = RobustScaler()\n",
    "x_scaled = scaler.fit_transform(x_imputed)\n",
    "\n",
    "# 8. Regularized Logistic Regression (Ridge / L2)\n",
    "model = LogisticRegression(penalty='l2',solver='liblinear',C=1.0)\n",
    "\n",
    "model.fit(x_scaled, y)\n",
    "\n",
    "# 9. Cross-validation \n",
    "scores = cross_val_score(model, x_scaled, y, cv=5)\n",
    "\n",
    "#10. Store results in a file\n",
    "with open(\"ML_Model_Outputs/regularized_logit_summary.txt\", \"w\") as f:\n",
    "    f.write(f\"Cross Validation Accuracy: {scores.mean()}\\n\")\n",
    "    f.write(f\"Std Dev: {scores.std()}\\n\")"
    "\"\"\"\n",
    "Comments and some code written by Google Gemini Pro 3.1\n",
    "\"\"\""
