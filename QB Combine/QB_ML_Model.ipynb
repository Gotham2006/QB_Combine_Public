    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.model_selection import cross_val_score\n",
    "from sklearn.impute import SimpleImputer\n",
    "from sklearn.ensemble import GradientBoostingClassifier\n",
    "\n",
    "# 1. Load data\n",
    "df = pd.read_csv('Data_Cleaning/QB_Combine_Data.csv')\n",
    "\n",
    "# 2. Convert height/broad\n",
    "def convert_to_inches(val):\n",
    "    if pd.isna(val) or str(val).strip() == \"\":\n",
    "        return np.nan\n",
    "    try:\n",
    "        v = str(val).strip().replace('\"', '')\n",
    "        if \"'\" in v:\n",
    "            f, i = v.split(\"'\")\n",
    "            return int(f) * 12 + (int(i) if i else 0)\n",
    "        return float(v)\n",
    "    except:\n",
    "        return np.nan\n",
    "\n",
    "df['Height'] = df[[c for c in df.columns if 'Height' in c][0]].apply(convert_to_inches)\n",
    "df['Broad_Jump'] = df[[c for c in df.columns if 'Broad' in c][0]].apply(convert_to_inches)\n",
    "\n",
    "# 3. Target (median split)\n",
    "pff_col = [c for c in df.columns if 'PFF' in c.upper()][0]\n",
    "df[pff_col] = pd.to_numeric(df[pff_col], errors='coerce')\n",
    "df = df.dropna(subset=[pff_col])\n",
    "\n",
    "y = (df[pff_col] >= df[pff_col].median()).astype(int)\n",
    "\n",
    "# 4. Base features\n",
    "features = [\n",
    "    'Height', 'Broad_Jump', 'Weight', 'Hands', 'Arms',\n",
    "    '40 Yd', 'Vertical', '3-Cone', 'Shuttle'\n",
    "]\n",
    "\n",
    "# 5. KEEP ONLY FEATURES WITH >= 20 NON-MISSING VALUES\n",
    "valid_features = [f for f in features if df[f].notna().sum() >= 20]\n",
    "\n",
    "# 6. Define X using filtered features\n",
    "x = df[valid_features]\n",
    "\n",
    "# 7. Impute missing values\n",
    "imputer = SimpleImputer(strategy='mean')\n",
    "x_imputed = imputer.fit_transform(x)\n",
    "\n",
    "# 8. Gradient Boosting model\n",
    "gb = GradientBoostingClassifier(\n",
    "    n_estimators=200,\n",
    "    learning_rate=0.05,\n",
    "    max_depth=2,\n",
    "    random_state=42\n",
    ")\n",
    "\n",
    "# 9. Cross-validation (robust evaluation)\n",
    "scores = cross_val_score(gb, x_imputed, y, cv=5)\n",
    "\n",
    "# 10. Fit final model for feature importance\n",
    "gb.fit(x_imputed, y)\n",
    "\n",
    "importance = pd.Series(gb.feature_importances_, index=valid_features)\n",
    "importance_sorted = importance.sort_values(ascending=False)\n",
    "\n",
    "with open(\"ML_Model_Outputs/Gradient_Boosting_Model.txt\", \"w\") as f:\n",
